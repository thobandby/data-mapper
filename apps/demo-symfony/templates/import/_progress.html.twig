{% set steps = [
    { key: 'upload', label: 'progress.upload'|trans },
    { key: 'schema', label: 'progress.schema'|trans },
    { key: 'mapping', label: 'progress.mapping'|trans },
    { key: 'result', label: 'progress.result'|trans },
] %}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap surface-muted p-3 p-md-4">
        {% for step in steps %}
            {% set isCurrent = step.key == current_step %}
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold {{ isCurrent ? 'text-dark' : '' }}" style="width: 2.2rem; height: 2.2rem; background: {{ isCurrent ? 'linear-gradient(135deg, #67e8f9, #38bdf8)' : 'rgba(148, 163, 184, 0.12)' }}; color: {{ isCurrent ? '#03111e' : '#cbd5e1' }};">
                    {{ loop.index }}
                </div>
                <div>
                    <div class="small text-uppercase fw-bold {{ isCurrent ? '' : 'text-muted' }}" style="letter-spacing: 0.08em;">{{ step.label }}</div>
                    <div class="small {{ isCurrent ? '' : 'text-muted' }}">{{ isCurrent ? 'progress.current'|trans : 'progress.pending'|trans }}</div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
