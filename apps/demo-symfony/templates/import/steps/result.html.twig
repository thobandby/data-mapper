{% include 'import/_progress.html.twig' with { current_step: current_step } only %}
{% include 'import/_flashes.html.twig' %}

<div class="step-panel">
    <div>
        <div class="eyebrow">{{ 'step.label'|trans({'%number%': 4}) }}</div>
        <h2 class="step-title">{{ 'result.title'|trans }}</h2>
        <p class="step-subtitle mb-0">{{ 'result.subtitle'|trans }}</p>
    </div>

    {% if async_job is defined %}
        <div class="section-card" id="async-job-panel" data-status-url="{{ async_status_url }}">
            <div class="card-body">
                <div class="eyebrow mb-2">{{ 'result.async.eyebrow'|trans }}</div>
                <h3 class="h4 mb-2">{{ 'result.async.title'|trans }}</h3>
                <p class="mb-2">{{ 'result.async.description'|trans({'%job_id%': async_job.id})|raw }}</p>
                <p class="mb-0">
                    <strong>{{ 'result.async.status'|trans }}:</strong> <span id="async-job-status">{{ async_job.status }}</span>
                    <br>
                    <strong>{{ 'result.async.status_endpoint'|trans }}:</strong> <a href="{{ async_status_url }}" target="_blank" rel="noreferrer">{{ async_status_url }}</a>
                </p>
                <div class="surface-muted p-3 mt-3 small" id="async-job-payload">
                    {{ 'result.async.payload_pending'|trans }}
                </div>
            </div>
        </div>

        <div class="alert alert-info mb-0">
            {{ 'result.async.consume_hint'|trans|raw }}
        </div>
    {% else %}
        <div class="row g-3 mb-1">
            <div class="col-md-4">
                <div class="result-stat text-center">
                    <h5 class="card-title text-muted text-uppercase small mb-3">{{ 'result.stats.processed'|trans }}</h5>
                    <p class="display-4">{{ result.processed }}</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="result-stat is-success text-center">
                    <h5 class="card-title text-muted text-uppercase small mb-3">{{ 'result.stats.imported'|trans }}</h5>
                    <p class="display-4">{{ result.imported }}</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="result-stat {{ result.errors is empty ? '' : 'is-danger' }} text-center">
                    <h5 class="card-title text-muted text-uppercase small mb-3">{{ 'result.stats.errors'|trans }}</h5>
                    <p class="display-4">{{ result.errors|length }}</p>
                </div>
            </div>
        </div>

        {% if result.errors is not empty %}
            <div class="section-card">
                <div class="card-header">
                    <div class="eyebrow mb-2">{{ 'result.validation.eyebrow'|trans }}</div>
                    <h3 class="h4 mb-0 text-danger">{{ 'result.validation.title'|trans }}</h3>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 100px;">{{ 'result.validation.row'|trans }}</th>
                                    <th>{{ 'result.validation.error'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for error in result.errors %}
                                    <tr>
                                        <td class="text-center"><strong>{{ error.rowIndex }}</strong></td>
                                        <td>
                                            <ul class="list-unstyled mb-0">
                                                {% for field, message in error.fieldErrors %}
                                                    <li><span class="badge-soft me-2">{{ field }}</span>{{ message }}</li>
                                                {% endfor %}
                                            </ul>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if adapter in ['json', 'xml', 'sql'] %}
            <div class="section-card">
                <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                    <div>
                        <div class="eyebrow mb-2">{{ 'result.export.eyebrow'|trans }}</div>
                        <h3 class="h4 mb-1">{{ 'result.export.title'|trans({'%format%': adapter|upper}) }}</h3>
                        <p class="text-muted mb-0">{{ 'result.export.description'|trans({'%format%': adapter|upper}) }}</p>
                    </div>
                    <a href="{{ path('import_download') }}" class="btn btn-primary" data-turbo="false" data-turbo-frame="_top" target="_top">
                        {{ 'result.export.download'|trans({'%format%': adapter|upper}) }}
                    </a>
                </div>
            </div>
        {% endif %}
    {% endif %}

    <div class="section-card">
        <div class="card-header">
            <div class="eyebrow mb-2">{{ 'result.selection.eyebrow'|trans }}</div>
            <h3 class="h4 mb-0">{{ 'result.selection.title'|trans }}</h3>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-lg-5">
                    <dl class="row small mb-0">
                        <dt class="col-sm-5">{{ 'result.selection.file'|trans }}</dt>
                        <dd class="col-sm-7">{{ file }}</dd>
                        <dt class="col-sm-5">{{ 'result.selection.file_type'|trans }}</dt>
                        <dd class="col-sm-7">{{ file_type|upper }}</dd>
                        <dt class="col-sm-5">{{ 'result.selection.adapter'|trans }}</dt>
                        <dd class="col-sm-7">{{ ('adapter.' ~ adapter)|trans }}</dd>
                        <dt class="col-sm-5">{{ 'result.selection.table'|trans }}</dt>
                        <dd class="col-sm-7"><code>{{ table_name }}</code></dd>
                        <dt class="col-sm-5">{{ 'result.selection.delimiter'|trans }}</dt>
                        <dd class="col-sm-7">
                            {% if delimiter %}
                                {{ delimiter == "\t" ? 'common.tab'|trans : delimiter }}
                            {% else %}
                                {{ 'result.selection.not_configured'|trans }}
                            {% endif %}
                        </dd>
                    </dl>
                </div>
                <div class="col-lg-7">
                    <div class="small text-uppercase text-muted mb-2">{{ 'result.selection.target_columns'|trans }}</div>
                    <div class="d-flex flex-wrap gap-1 mb-3">
                        {% for column in target_columns %}
                            <span class="badge-soft">{{ column }}</span>
                        {% else %}
                            <span class="text-muted small">{{ 'result.selection.no_target_columns'|trans }}</span>
                        {% endfor %}
                    </div>

                    <div class="small text-uppercase text-muted mb-2">{{ 'result.selection.mapping'|trans }}</div>
                    <div class="d-grid gap-2">
                        {% set active_mapping_count = 0 %}
                        {% for source, target in mapping %}
                            {% if target != '' %}
                                {% set active_mapping_count = active_mapping_count + 1 %}
                                <div class="surface-muted px-3 py-2 rounded small d-flex justify-content-between gap-3">
                                    <code>{{ source }}</code>
                                    <span>&rarr;</span>
                                    <code>{{ target }}</code>
                                </div>
                            {% endif %}
                        {% endfor %}
                        {% if active_mapping_count == 0 %}
                            <div class="text-muted small">{{ 'result.selection.no_mapping'|trans }}</div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-2">
        <a href="{{ path('import_index') }}" class="btn btn-primary">{{ 'result.restart'|trans }}</a>
    </div>
</div>

{% if async_job is defined %}
<script>
    (() => {
        const panel = document.getElementById('async-job-panel');
        if (!panel) {
            return;
        }

        const statusEl = document.getElementById('async-job-status');
        const payloadEl = document.getElementById('async-job-payload');
        const statusUrl = panel.dataset.statusUrl;
        const terminalStates = new Set(['completed', 'failed']);

        const updatePayload = (job) => {
            if (!payloadEl) {
                return;
            }

            if (job.error) {
                payloadEl.textContent = `{{ 'result.async.payload_error'|trans|e('js') }}: ${job.error}`;
                return;
            }

            if (job.result) {
                payloadEl.textContent = `{{ 'result.async.payload_result'|trans|e('js') }}: ${JSON.stringify(job.result)}`;
                return;
            }

            payloadEl.textContent = '{{ 'result.async.payload_running'|trans|e('js') }}';
        };

        const poll = async () => {
            try {
                const response = await fetch(statusUrl, { headers: { Accept: 'application/json' } });
                if (!response.ok) {
                    return;
                }

                const job = await response.json();
                if (statusEl && job.status) {
                    statusEl.textContent = job.status;
                }
                updatePayload(job);

                if (!terminalStates.has(job.status)) {
                    window.setTimeout(poll, 2000);
                }
            } catch (error) {
                if (payloadEl) {
                    payloadEl.textContent = '{{ 'result.async.payload_failed_poll'|trans|e('js') }}';
                }
            }
        };

        window.setTimeout(poll, 1200);
    })();
</script>
{% endif %}
