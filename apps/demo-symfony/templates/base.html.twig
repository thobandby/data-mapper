<!DOCTYPE html>
<html lang="{{ app.request.locale|default('de') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ 'app.title'|trans }}{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
        <script type="module" src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.12/dist/turbo.es2017-esm.js"></script>
        <script nomodule src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.12/dist/turbo.es2017-umd.js"></script>
        <style>
            :root {
                --page-bg: #08111f;
                --page-accent: #5ed3ff;
                --page-accent-strong: #0ea5e9;
                --page-accent-soft: rgba(94, 211, 255, 0.14);
                --page-panel: rgba(9, 18, 35, 0.88);
                --page-panel-strong: rgba(12, 22, 43, 0.96);
                --page-border: rgba(148, 163, 184, 0.16);
                --page-text: #e2e8f0;
                --page-muted: #93a4bd;
                --page-highlight: #8b5cf6;
                --page-success: #22c55e;
                --page-danger: #fb7185;
                --page-warning: #f59e0b;
                --page-shadow: 0 28px 90px rgba(2, 6, 23, 0.48);
                --page-radius: 28px;
            }

            body {
                min-height: 100vh;
                color: var(--page-text);
                font-family: "Source Sans 3", sans-serif;
                background:
                    radial-gradient(circle at top left, rgba(14, 165, 233, 0.22), transparent 28%),
                    radial-gradient(circle at top right, rgba(139, 92, 246, 0.16), transparent 24%),
                    linear-gradient(180deg, #0b1220 0%, var(--page-bg) 52%, #050b16 100%);
            }

            h1, h2, h3, h4, h5, h6, .font-display {
                font-family: "Space Grotesk", sans-serif;
                letter-spacing: -0.03em;
            }

            .app-shell {
                width: min(1120px, calc(100vw - 2rem));
                margin: 0 auto;
                padding: 40px 0 64px;
            }

            .app-frame {
                position: relative;
                overflow: hidden;
                border: 1px solid var(--page-border);
                border-radius: var(--page-radius);
                background: linear-gradient(180deg, rgba(12, 20, 39, 0.96), rgba(8, 17, 31, 0.96));
                box-shadow: var(--page-shadow);
                backdrop-filter: blur(18px);
            }

            .app-frame::before {
                content: "";
                position: absolute;
                inset: 0;
                background:
                    radial-gradient(circle at 0% 0%, rgba(14, 165, 233, 0.16), transparent 24%),
                    radial-gradient(circle at 100% 10%, rgba(139, 92, 246, 0.14), transparent 20%);
                pointer-events: none;
            }

            .app-flashes {
                display: grid;
                gap: 0.75rem;
                margin-bottom: 1.5rem;
            }

            .app-flashes .alert {
                margin-bottom: 0;
                border: 0;
                border-radius: 18px;
                color: var(--page-text);
                box-shadow: 0 10px 30px rgba(2, 6, 23, 0.22);
                background: rgba(15, 23, 42, 0.88);
            }

            .wizard-header {
                position: relative;
                padding: 2rem 2rem 1.5rem;
                border-bottom: 1px solid var(--page-border);
                background:
                    linear-gradient(135deg, rgba(3, 10, 23, 0.98), rgba(12, 28, 54, 0.94));
                color: #f8fbff;
            }

            .wizard-header p {
                color: rgba(226, 232, 240, 0.76);
                max-width: 48rem;
                margin-bottom: 0;
            }

            .wizard-header::after {
                content: "";
                position: absolute;
                inset: auto 2rem 0 auto;
                width: 220px;
                height: 220px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(94, 211, 255, 0.3), transparent 65%);
                transform: translate(30%, 35%);
                pointer-events: none;
            }

            .wizard-kicker {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.45rem 0.8rem;
                border-radius: 999px;
                font-size: 0.8rem;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                background: rgba(94, 211, 255, 0.1);
                color: #7dd3fc;
                margin-bottom: 1rem;
            }

            .wizard-body {
                position: relative;
                padding: 2rem;
                min-width: 0;
            }

            turbo-frame {
                display: block;
                min-width: 0;
            }

            .step-panel {
                display: grid;
                gap: 1.5rem;
                min-width: 0;
            }

            .section-card {
                border: 1px solid rgba(148, 163, 184, 0.14);
                border-radius: 22px;
                background: var(--page-panel-strong);
                box-shadow: 0 14px 38px rgba(2, 6, 23, 0.22);
                min-width: 0;
            }

            .section-card .card-header {
                padding: 1rem 1.25rem;
                border-bottom: 1px solid rgba(148, 163, 184, 0.12);
                background: transparent;
            }

            .section-card .card-body,
            .section-card .card-footer {
                padding: 1.25rem;
            }

            .eyebrow {
                font-size: 0.78rem;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: #7dd3fc;
                margin-bottom: 0.5rem;
            }

            .step-title {
                margin-bottom: 0.4rem;
            }

            .step-subtitle,
            .meta-inline {
                color: var(--page-muted);
            }

            .meta-inline {
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem;
                font-size: 0.95rem;
            }

            .meta-chip {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                padding: 0.45rem 0.75rem;
                border-radius: 999px;
                background: var(--page-accent-soft);
                color: #bae6fd;
                font-weight: 600;
                border: 1px solid rgba(94, 211, 255, 0.14);
            }

            .form-control,
            .form-select {
                min-height: 3rem;
                color: var(--page-text);
                background: rgba(15, 23, 42, 0.9);
                border-color: rgba(148, 163, 184, 0.18);
                border-radius: 14px;
                box-shadow: none;
            }

            .form-control::placeholder {
                color: rgba(148, 163, 184, 0.72);
            }

            .form-control:focus,
            .form-select:focus {
                color: var(--page-text);
                background: rgba(15, 23, 42, 0.96);
                border-color: rgba(94, 211, 255, 0.68);
                box-shadow: 0 0 0 0.24rem rgba(94, 211, 255, 0.14);
            }

            .btn {
                border-radius: 14px;
                font-weight: 700;
                padding: 0.8rem 1.15rem;
            }

            .btn-primary {
                color: #03111e;
                border-color: #67e8f9;
                background: linear-gradient(135deg, #67e8f9, #38bdf8);
            }

            .btn-primary:hover,
            .btn-primary:focus {
                color: #03111e;
                border-color: #a5f3fc;
                background: linear-gradient(135deg, #a5f3fc, #38bdf8);
            }

            .btn-secondary {
                border-color: rgba(148, 163, 184, 0.24);
                background: rgba(30, 41, 59, 0.96);
                color: var(--page-text);
            }

            .btn-secondary:hover,
            .btn-secondary:focus {
                border-color: rgba(94, 211, 255, 0.28);
                background: rgba(15, 23, 42, 0.96);
                color: var(--page-text);
            }

            .btn-outline-secondary {
                color: #cbd5e1;
                border-color: rgba(148, 163, 184, 0.24);
            }

            .btn-outline-secondary:hover,
            .btn-outline-secondary:focus {
                color: #f8fafc;
                background: rgba(30, 41, 59, 0.8);
                border-color: rgba(148, 163, 184, 0.34);
            }

            .btn-link {
                color: #7dd3fc;
                font-weight: 700;
                text-decoration: none;
            }

            .btn-link:hover {
                color: #bae6fd;
            }

            .table {
                --bs-table-bg: transparent;
                --bs-table-color: var(--page-text);
                --bs-table-striped-color: var(--page-text);
            }

            .table-responsive {
                max-width: 100%;
                overflow-x: auto;
                overflow-y: hidden;
                -webkit-overflow-scrolling: touch;
            }

            .table thead th {
                font-size: 0.8rem;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                color: var(--page-muted);
                border-bottom-width: 1px;
            }

            .table > :not(caption) > * > * {
                padding: 0.9rem 1rem;
                border-color: rgba(148, 163, 184, 0.1);
            }

            .table-hover tbody tr:hover {
                --bs-table-accent-bg: rgba(94, 211, 255, 0.05);
            }

            .badge-soft {
                display: inline-flex;
                align-items: center;
                padding: 0.45rem 0.7rem;
                border-radius: 999px;
                background: rgba(94, 211, 255, 0.1);
                color: #bae6fd;
                font-weight: 700;
            }

            .mapping-board {
                display: grid;
                gap: 0.9rem;
            }

            .mapping-row {
                display: grid;
                grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
                gap: 0.9rem;
                align-items: center;
                padding: 1rem;
                border: 1px solid rgba(148, 163, 184, 0.14);
                border-radius: 18px;
                background: linear-gradient(180deg, rgba(14, 23, 42, 0.94), rgba(10, 18, 35, 0.98));
            }

            .mapping-box {
                min-width: 0;
                padding: 0.9rem 1rem;
                border-radius: 16px;
                border: 1px solid rgba(148, 163, 184, 0.14);
                background: rgba(8, 15, 29, 0.82);
            }

            .mapping-box.is-source {
                border-color: rgba(94, 211, 255, 0.18);
                background: linear-gradient(180deg, rgba(12, 28, 54, 0.72), rgba(7, 18, 35, 0.92));
            }

            .mapping-box.is-target {
                border-color: rgba(125, 211, 252, 0.14);
            }

            .mapping-box-label {
                display: block;
                margin-bottom: 0.45rem;
                font-size: 0.74rem;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--page-muted);
            }

            .mapping-box-value {
                display: block;
                overflow-wrap: anywhere;
                font-weight: 700;
                color: #f8fbff;
            }

            .mapping-arrow {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 2.5rem;
                height: 2.5rem;
                border-radius: 999px;
                border: 1px solid rgba(94, 211, 255, 0.18);
                background: rgba(94, 211, 255, 0.08);
                color: #7dd3fc;
                font-size: 1.1rem;
                font-weight: 700;
                flex-shrink: 0;
            }

            .mapping-target-control .form-select,
            .mapping-target-control .form-control {
                min-height: 3.25rem;
            }

            .schema-column-board {
                display: grid;
                gap: 0.9rem;
                min-width: 0;
            }

            .schema-column-row {
                display: grid;
                grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto;
                gap: 0.9rem;
                align-items: center;
                padding: 1rem;
                border: 1px solid rgba(148, 163, 184, 0.14);
                border-radius: 18px;
                background: linear-gradient(180deg, rgba(14, 23, 42, 0.94), rgba(10, 18, 35, 0.98));
            }

            #new_table_setup {
                min-width: 0;
            }

            .schema-preview-table {
                min-width: max-content;
            }

            .schema-column-toggle {
                display: inline-flex;
                align-items: center;
                gap: 0.6rem;
                padding: 0.85rem 1rem;
                border-radius: 16px;
                border: 1px solid rgba(148, 163, 184, 0.14);
                background: rgba(8, 15, 29, 0.82);
                min-height: 3.25rem;
            }

            .schema-column-toggle .form-check {
                margin: 0;
            }

            .schema-column-toggle .form-check-input {
                float: none;
                margin: 0;
            }

            .schema-column-toggle-label {
                font-size: 0.74rem;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--page-muted);
            }

            .result-stat {
                height: 100%;
                padding: 1.35rem;
                border: 1px solid rgba(148, 163, 184, 0.12);
                border-radius: 22px;
                background: linear-gradient(180deg, rgba(15, 23, 42, 0.94), rgba(11, 18, 32, 0.98));
                box-shadow: 0 12px 34px rgba(2, 6, 23, 0.18);
            }

            .result-stat .display-4 {
                font-family: "Space Grotesk", sans-serif;
                font-size: clamp(2rem, 4vw, 3rem);
                margin-bottom: 0;
            }

            .result-stat.is-success {
                background: linear-gradient(180deg, rgba(34, 197, 94, 0.16), rgba(15, 23, 42, 0.98));
            }

            .result-stat.is-danger {
                background: linear-gradient(180deg, rgba(251, 113, 133, 0.18), rgba(15, 23, 42, 0.98));
            }

            .surface-muted {
                border: 1px dashed rgba(94, 211, 255, 0.18);
                border-radius: 18px;
                background: rgba(15, 23, 42, 0.58);
            }

            .surface-accent {
                border: 1px solid rgba(94, 211, 255, 0.16);
                border-radius: 18px;
                background: linear-gradient(180deg, rgba(10, 23, 43, 0.92), rgba(6, 15, 31, 0.96));
            }

            .text-muted,
            .form-text,
            .small.text-muted {
                color: var(--page-muted) !important;
            }

            .alert-info,
            .alert-success,
            .alert-warning {
                color: var(--page-text);
                background: rgba(15, 23, 42, 0.9);
            }

            .alert-warning {
                border: 1px solid rgba(245, 158, 11, 0.24);
            }

            .alert-success {
                border: 1px solid rgba(34, 197, 94, 0.22);
            }

            .alert-info {
                border: 1px solid rgba(94, 211, 255, 0.22);
            }

            code {
                color: #93c5fd;
            }

            a {
                color: #7dd3fc;
            }

            a:hover {
                color: #bae6fd;
            }

            @media (max-width: 767.98px) {
                .app-shell {
                    width: min(100vw - 1rem, 100%);
                    padding-top: 0.75rem;
                }

                .wizard-header,
                .wizard-body {
                    padding: 1.25rem;
                }

                .section-card .card-body,
                .section-card .card-footer,
                .section-card .card-header {
                    padding: 1rem;
                }

                .mapping-row {
                    grid-template-columns: 1fr;
                }

                .mapping-arrow {
                    width: 100%;
                    height: 2.2rem;
                }

                .schema-column-row {
                    grid-template-columns: 1fr;
                }

                .schema-column-toggle {
                    justify-content: space-between;
                }
            }
        </style>
    </head>
    <body>
        <div class="app-shell">
            {% block body %}{% endblock %}
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    </body>
</html>
